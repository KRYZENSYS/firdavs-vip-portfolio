# FirdavsVIP Environment Variables
# Copy this file to .env.local and fill in your values

# GroqCloud AI API Key (get from https://console.groq.com)
NEXT_PUBLIC_GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Site configuration
NEXT_PUBLIC_SITE_URL=https://firdavsvip.vercel.app

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=

# Optional: Sentry
# SENTRY_DSN=
